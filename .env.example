# ============================================================================
# Athena Pentest Stack — Environment Configuration
# Copy to .env and fill in your values
# ============================================================================

# ============================================================================
# Gateway
# ============================================================================
GATEWAY_LISTEN_IP=127.0.0.1
GATEWAY_LISTEN_PORT=8443
PUBLIC_URL=https://localhost:8443
CORS_ORIGINS=https://localhost:8443
COOKIE_SIGNING_SALT=CHANGE_ME_random_salt_string

# ============================================================================
# Database
# ============================================================================
POSTGRES_USER=athena
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=athena_pentest

# ============================================================================
# LLM Provider
# ============================================================================
# OpenRouter (recommended — cheapest per-token, many model choices)
OPENROUTER_KEY=sk-or-v1-CHANGE_ME

# Or use direct providers:
# OPEN_AI_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...

# ============================================================================
# Search Engines (optional but recommended)
# ============================================================================
# TAVILY_API_KEY=tvly-...
# PERPLEXITY_API_KEY=pplx-...

# ============================================================================
# Storage
# ============================================================================
# Where pentest results/evidence are stored on the host
PENTEST_RESULTS_DIR=/opt/pentest-results

# ============================================================================
# Network (for external access)
# ============================================================================
# To access from other machines:
# GATEWAY_LISTEN_IP=0.0.0.0
# PUBLIC_URL=https://192.168.1.50:8443
# CORS_ORIGINS=https://localhost:8443,https://192.168.1.50:8443
