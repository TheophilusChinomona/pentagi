# ============================================================================
# Athena Pentest — Infisical Secrets Reference
#
# This file is no longer used by the stack — secrets are pulled from Infisical
# at runtime via `infisical run --env=<env> -- docker compose ...`.
#
# It documents which secrets need to exist in your Infisical project, per
# environment (dev / staging / prod). Add them in the Infisical UI or via:
#   infisical secrets set NAME=value --env=<env>
# ============================================================================

# ---- Required ----

# Full Postgres connection URL to your ParadeDB / pgvector instance.
# The agent auto-creates schema `hermes_memory` on first connect, no migrations.
# pg_search extension is used for BM25 if available (ParadeDB has it),
# else falls back to tsvector.
HERMES_MEMORY_DATABASE_URL=postgresql://user:pass@paradedb.example.com:5432/athena

# OpenRouter key — used both for LLM calls and for embeddings (via the
# LANCEDB_EMBED_PROVIDER=openrouter setting in compose).
OPENROUTER_API_KEY=sk-or-v1-...

# ---- Optional (image selection) ----
# Tag pulled from registry.gitlab.com/chinomonatinotenda19/athena and
# .../athena-pentest/{pentest-tools,code-tools}. CI in those repos must publish
# the tag you reference here. Defaults to "stable" if unset.
IMAGE_TAG=stable                       # dev | staging | prod | stable | latest

# Per-image overrides — only set if you need to pin a different repo or tag
# than the IMAGE_TAG default.
# PENTEST_TOOLS_IMAGE=registry.gitlab.com/chinomonatinotenda19/athena-pentest/pentest-tools:stable
# CODE_TOOLS_IMAGE=registry.gitlab.com/chinomonatinotenda19/athena-pentest/code-tools:stable

# ---- Optional (embedding model) ----
# Defaults below are baked into compose; override only if you want a different
# embedding provider/model.
# LANCEDB_EMBED_PROVIDER=openrouter
# LANCEDB_EMBED_MODEL=openai/text-embedding-3-small

# ---- Optional (gateway / network config) ----
# These can also be passed as CLI flags to setup.sh (--listen-ip, --listen-port,
# --public-url). Setting them in Infisical lets each env have its own values.
# GATEWAY_LISTEN_IP=127.0.0.1
# GATEWAY_LISTEN_PORT=8443
# PUBLIC_URL=https://localhost:8443
# CORS_ORIGINS=https://localhost:8443
# TZ=Africa/Johannesburg

# ---- Optional (storage) ----
# PENTEST_RESULTS_DIR=/opt/pentest-results
